{
  "name": "ember-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "prisma generate --schema=../../prisma/schema.prisma && nest build",
    "start": "nest start",
    "dev": "nest start --watch",
    "db:migrate": "prisma migrate dev --schema=../../prisma/schema.prisma",
    "db:generate": "prisma generate --schema=../../prisma/schema.prisma"
  },
  "dependencies": {
    "@ember/config": "workspace:*",
    "@ember/hotstuff-client": "workspace:*",
    "@ember/strategies": "workspace:*",
    "@ember/types": "workspace:*",
    "@msgpack/msgpack": "^2.8.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@prisma/client": "^5.0.0",
    "bullmq": "^5.8.0",
    "dotenv": "^17.4.2",
    "ioredis": "^5.4.0",
    "siwe": "^2.3.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "prisma": "^5.0.0",
    "typescript": "^5.0.0"
  }
}
